{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "main": "build/electron/main.js",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "electron-devtools-installer": "^3.2.0",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/electron-devtools-installer": "^2.2.2",
    "@types/jest": "^29.4.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.37",
    "@types/react-dom": "^18.0.11",
    "cross-env": "^7.0.3",
    "concurrently": "^8.0.1",
    "electron": "41.0.2",
    "electron-builder": "^25.0.0",
    "electron-is-dev": "^2.0.0",
    "typescript": "^5.0.4",
    "wait-on": "^7.0.1",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "eslint-config-prettier": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "globals": "^15.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "typescript-eslint": "^8.0.0",
    "eslint": "^9.0.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest",
    "electron:dev": "concurrently \"npm run start\" \"wait-on http://localhost:5173 && tsc -p electron --skipLibCheck -w\" \"wait-on http://localhost:5173 && tsc -p electron --skipLibCheck && electron .\"",
    "electron:build": "npm run build && tsc -p electron --skipLibCheck && electron-builder",
    "electron:dist": "npm run build && tsc -p electron --skipLibCheck && electron-builder --mac --dir"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "build": {
    "productName": "productName",
    "mac": {
      "target": {
        "target": "default",
        "arch": [
          "universal"
        ]
      },
      "category": "public.app-category.productivity"
    },
    "extends": null,
    "files": [
      "build/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
